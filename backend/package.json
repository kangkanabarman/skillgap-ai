{
  "name": "skillgap-backend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "ai": "cd ai-engine && ./scripts/start-ai.sh",
